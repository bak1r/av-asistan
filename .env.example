# Veritabanı
DATABASE_URL=postgresql+asyncpg://avukat:avukat_dev_123@localhost:5432/avukat
DB_PASSWORD=avukat_dev_123

# Embedding modeli
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSION=384

# LLM Sağlayıcı: "ollama" | "claude" | "openai"
LLM_PROVIDER=ollama

# Ollama (varsayılan - ücretsiz, yerel)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Claude API (opsiyonel)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI API (opsiyonel)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Arama ayarları
SEARCH_TOP_K=10
HYBRID_VECTOR_WEIGHT=0.6
HYBRID_BM25_WEIGHT=0.4

# Uygulama
APP_TITLE=Avukat AI
DEBUG=true
